{
  "name": "DMS Service Job",
  "module": "DMS",
  "doctype": "DocType",
  "autoname": "format:SVC-{company_id:.3}-{YYYY}-{#####}",
  "is_submittable": 1,
  "fields": [
    { "fieldname": "company_id", "fieldtype": "Link", "options": "DMS Company", "label": "Company", "reqd": 1 },
    { "fieldname": "customer_id", "fieldtype": "Link", "options": "DMS Customer", "label": "Customer", "reqd": 1, "in_list_view": 1 },
    { "fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer_id.customer_name", "read_only": 1 },
    { "fieldname": "vehicle_reg_no", "fieldtype": "Data", "label": "Vehicle Reg No", "reqd": 1, "in_list_view": 1 },
    { "fieldname": "model", "fieldtype": "Data", "label": "Model" },
    { "fieldname": "service_type", "fieldtype": "Select", "label": "Service Type", "options": "General Service\nRepair\nAccidental\nAMC\nPDI" },
    { "fieldname": "km_reading", "fieldtype": "Int", "label": "KM Reading" },
    { "fieldname": "complaint", "fieldtype": "Text", "label": "Customer Complaint" },
    { "fieldname": "service_items", "fieldtype": "Table", "label": "Service Items", "options": "DMS Service Item" },
    { "fieldname": "labour_charges", "fieldtype": "Currency", "label": "Labour Charges" },
    { "fieldname": "parts_charges", "fieldtype": "Currency", "label": "Parts Charges" },
    { "fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "in_list_view": 1 },
    { "fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Open\nIn Progress\nCompleted\nDelivered\nCancelled", "default": "Open", "in_list_view": 1 },
    { "fieldname": "expected_delivery", "fieldtype": "Datetime", "label": "Expected Delivery" },
    { "fieldname": "actual_delivery", "fieldtype": "Datetime", "label": "Actual Delivery" }
  ],
  "permissions": [
    { "role": "Group Admin", "read": 1, "write": 1, "create": 1, "submit": 1 },
    { "role": "Honda Manager", "read": 1, "write": 1, "create": 1, "submit": 1 },
    { "role": "Honda User", "read": 1, "write": 1, "create": 1 },
    { "role": "NEXA Manager", "read": 1, "write": 1, "create": 1, "submit": 1 },
    { "role": "NEXA User", "read": 1, "write": 1, "create": 1 },
    { "role": "Jaguar Manager", "read": 1, "write": 1, "create": 1, "submit": 1 },
    { "role": "Jaguar User", "read": 1, "write": 1, "create": 1 }
  ]
}
